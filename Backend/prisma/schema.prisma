generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CustomerIdentifier {
  customer_id           Int                   @id @default(autoincrement()) @map("customer_id")
  customer_email        String                @unique @db.VarChar(255)
  customer_phone_number String                @db.VarChar(255)
  customer_added_date   DateTime?             @default(now()) @map("customer_added_date")
  customer_hash         String                @db.VarChar(255)
  customer_info         CustomerInfo[]
  customer_vehicles     CustomerVehicleInfo[]
  orders                Order[]

  @@map("customer_identifier")
}

model CustomerInfo {
  customer_info_id       Int                @id @default(autoincrement()) @map("customer_info_id")
  customer_id            Int                @map("customer_id")
  customer_first_name    String             @db.VarChar(255)
  customer_last_name     String             @db.VarChar(255)
  active_customer_status Int
  customer               CustomerIdentifier @relation(fields: [customer_id], references: [customer_id])

  @@map("customer_info")
}

model CustomerVehicleInfo {
  vehicle_id      Int                @id @default(autoincrement()) @map("vehicle_id")
  customer_id     Int                @map("customer_id")
  vehicle_year    Int
  vehicle_make    String             @db.VarChar(255)
  vehicle_model   String             @db.VarChar(255)
  vehicle_type    String             @db.VarChar(255)
  vehicle_mileage Int
  vehicle_tag     String             @db.VarChar(255)
  vehicle_serial  String             @db.VarChar(255)
  vehicle_color   String             @db.VarChar(255)
  customer        CustomerIdentifier @relation(fields: [customer_id], references: [customer_id])
  orders          Order[]

  @@map("customer_vehicle_info")
}

model CompanyRole {
  company_role_id   Int            @id @default(autoincrement()) @map("company_role_id")
  company_role_name String         @unique @db.VarChar(255)
  employee_roles    EmployeeRole[]

  @@map("company_roles")
}

model CommonService {
  service_id          Int            @id @default(autoincrement()) @map("service_id")
  service_name        String         @db.VarChar(255)
  service_description String?
  order_services      OrderService[]

  @@map("common_services")
}

model Employee {
  employee_id     Int            @id @default(autoincrement()) @map("employee_id")
  employee_email  String         @unique @db.VarChar(255)
  active_employee Int
  added_date      DateTime?      @default(now()) @map("added_date")
  employee_info   EmployeeInfo[]
  employee_pass   EmployeePass[]
  employee_roles  EmployeeRole[]
  orders          Order[]

  @@map("employee")
}

model EmployeeInfo {
  employee_info_id    Int      @id @default(autoincrement()) @map("employee_info_id")
  employee_id         Int      @map("employee_id")
  employee_first_name String   @db.VarChar(255)
  employee_last_name  String   @db.VarChar(255)
  employee_phone      String   @db.VarChar(255)
  employee            Employee @relation(fields: [employee_id], references: [employee_id])

  @@map("employee_info")
}

model EmployeePass {
  employee_pass_id         Int      @id @default(autoincrement()) @map("employee_pass_id")
  employee_id              Int      @map("employee_id")
  employee_password_hashed String   @db.VarChar(255)
  employee                 Employee @relation(fields: [employee_id], references: [employee_id])

  @@map("employee_pass")
}

model EmployeeRole {
  employee_role_id Int         @id @default(autoincrement()) @map("employee_role_id")
  employee_id      Int         @map("employee_id")
  company_role_id  Int         @map("company_role_id")
  company_role     CompanyRole @relation(fields: [company_role_id], references: [company_role_id])
  employee         Employee    @relation(fields: [employee_id], references: [employee_id])

  @@map("employee_role")
}

model Order {
  order_id       Int                 @id @default(autoincrement()) @map("order_id")
  employee_id    Int                 @map("employee_id")
  customer_id    Int                 @map("customer_id")
  vehicle_id     Int                 @map("vehicle_id")
  order_date     DateTime?           @default(now()) @map("order_date")
  active_order   Int
  order_hash     String              @db.VarChar(255)
  order_info     OrderInfo[]
  order_services OrderService[]
  order_statuses OrderStatus[]
  customer       CustomerIdentifier  @relation(fields: [customer_id], references: [customer_id])
  employee       Employee            @relation(fields: [employee_id], references: [employee_id])
  vehicle        CustomerVehicleInfo @relation(fields: [vehicle_id], references: [vehicle_id])

  @@map("orders")
}

model OrderInfo {
  order_info_id                 Int       @id @default(autoincrement()) @map("order_info_id")
  order_id                      Int       @map("order_id")
  order_total_price             Int
  estimated_completion_date     DateTime? @default(now()) @map("estimated_completion_date")
  completion_date               DateTime? @map("completion_date")
  additional_request            String?
  notes_for_internal_use        String?
  notes_for_customer            String?
  additional_requests_completed Int
  order                         Order     @relation(fields: [order_id], references: [order_id])

  @@map("order_info")
}

model OrderService {
  order_service_id  Int           @id @default(autoincrement()) @map("order_service_id")
  order_id          Int           @map("order_id")
  service_id        Int           @map("service_id")
  service_completed Int
  order             Order         @relation(fields: [order_id], references: [order_id])
  service           CommonService @relation(fields: [service_id], references: [service_id])

  @@map("order_services")
}

model OrderStatus {
  order_status_id Int   @id @default(autoincrement()) @map("order_status_id")
  order_id        Int   @map("order_id")
  order_status    Int
  order           Order @relation(fields: [order_id], references: [order_id])

  @@map("order_status")
}
